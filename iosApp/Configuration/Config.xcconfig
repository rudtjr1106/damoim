PRODUCT_NAME=Damoim

// 안드로이드 패키지명과 동일하게 맞춘 출시용 번들 ID.
// ⚠️ 카카오 개발자 콘솔의 iOS 플랫폼에 이 값이 등록돼 있어야 카카오톡 로그인이 동작한다.
//    바꾸면 콘솔도 함께 바꿀 것. (템플릿 기본값은 개발자별 충돌을 피하려고 $(TEAM_ID)를
//    접미사로 붙였는데, 출시 앱에 팀 ID가 박히면 곤란해서 떼고 DEVELOPMENT_TEAM만 따로 받는다.)
PRODUCT_BUNDLE_IDENTIFIER=com.damoim.app

// 실기기 서명에 필요한 개발 팀. 비어 있으면 시뮬레이터만 빌드된다(서명 불필요).
// 개발자/머신마다 달라 커밋하지 않는다 → local.properties의 ios.team.id 로 넣으면
// 아래 Secrets.xcconfig 로 주입된다.
TEAM_ID=

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// ── 개발자별/비밀 설정 주입 (Gradle이 local.properties에서 생성, 커밋 제외) ──
//   재생성: ./gradlew :shared:generateIosSecretsXcconfig
//   '?' = 파일이 없어도 빌드가 깨지지 않는다(카카오 키 없으면 로그인만, TEAM_ID 없으면 실기기만 비활성).
// ⚠️ 반드시 파일 '맨 아래'에 둘 것 — xcconfig는 나중 할당이 이기므로, 위에 두면 이 아래의
//    TEAM_ID= 기본값이 주입값을 도로 덮어쓴다.
// ⚠️ xcconfig는 Xcode가 '빌드 페이즈 실행 전'에 읽는다 → Gradle Run Script가 이 파일을 새로
//    만들어도 그 빌드엔 반영되지 않고 '다음 빌드'부터 적용된다. 최초 1회와 값 변경 시엔
//    반드시 Xcode 밖에서 위 태스크를 먼저 실행할 것.
// ⚠️ 서버 URL을 여기 넣지 말 것 — xcconfig는 '//'를 주석으로 먹어 https:// 가 깨진다.
//    서버 주소는 iosMain의 IosBuildConfig(Gradle 생성 Kotlin 상수)로 간다.
#include? "Secrets.xcconfig"
